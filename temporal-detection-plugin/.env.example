# FiftyOne Enterprise Deployment Credentials
# Copy this file to .env and fill in your actual credentials:
#   cp .env.example .env
#
# NEVER commit .env — it is gitignored.

# Your dev environment (default for all projects)
FIFTYONE_API_URI=https://<your-deployment-name>.dev.fiftyone.ai
FIFTYONE_API_KEY=<your-api-key>

# PyPI Token for FiftyOne package installation
FIFTYONE_PYPI_TOKEN=<your-pypi-token>
